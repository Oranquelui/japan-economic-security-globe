PREFIX jpsdg: <https://data.jp-strategic-dependency-graph.org/ontology#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?flow ?label ?capability ?capabilityLabel ?source WHERE {
  ?flow a jpsdg:DependencyFlow ;
    jpsdg:theme "defense" ;
    rdfs:label ?label ;
    jpsdg:dependsOn ?capability .
  ?capability rdfs:label ?capabilityLabel .
  OPTIONAL { ?flow prov:wasDerivedFrom ?source . }
}
