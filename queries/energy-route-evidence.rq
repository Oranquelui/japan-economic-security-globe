PREFIX jpsdg: <https://data.jp-strategic-dependency-graph.org/ontology#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?flow ?label ?route ?routeLabel ?source WHERE {
  ?flow a jpsdg:DependencyFlow ;
    jpsdg:theme "energy" ;
    rdfs:label ?label ;
    jpsdg:transitsVia ?route .
  ?route rdfs:label ?routeLabel .
  FILTER(?routeLabel = "Strait of Hormuz")
  OPTIONAL { ?flow prov:wasDerivedFrom ?source . }
}
