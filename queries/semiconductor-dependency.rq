PREFIX jpsdg: <https://data.jp-strategic-dependency-graph.org/ontology#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?flow ?label ?country ?countryLabel ?product ?source WHERE {
  ?flow a jpsdg:DependencyFlow ;
    jpsdg:theme "semiconductors" ;
    rdfs:label ?label ;
    jpsdg:importsFrom ?country ;
    jpsdg:dependsOn ?product .
  ?country a jpsdg:Country ;
    rdfs:label ?countryLabel .
  OPTIONAL { ?flow prov:wasDerivedFrom ?source . }
}
